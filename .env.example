HASHIT_BASE_URL=https://your-domain.com
HASHIT_UPLOAD_DIR=/data/uploads
HASHIT_MAX_SIZE_MB=512
HASHIT_MAX_TTL_HOURS=168
HASHIT_SECRET=change_this_to_a_random_64_char_string
HASHIT_ADMIN_TOKEN=change_this_to_a_random_token
HASHIT_BEHIND_PROXY=1
HASHIT_RL_UPLOAD=20
HASHIT_RL_DOWNLOAD=120

# Cloudflare Tunnel Configuration (Optional)
# If left empty, a free Cloudflare Quick Tunnel with a random subdomain (trycloudflare.com) is generated automatically.
# Set this token to run a persistent Named Tunnel bound to your custom Cloudflare domain.
TUNNEL_TOKEN=
